<launch>

  <!-- ========================================================== -->
  <!-- Launch Arguments                                           -->
  <!-- ========================================================== -->

  <!-- Namespace -->
  <arg name="robot_name" default="lmr1"/>
  <arg name="namespace" default="$(arg robot_name)"/>

  <!-- Simulation world -->
  <arg name="world_name"
       default="$(find dynamic_obstacles)/worlds/cafe.world"/>

  <!-- Initial robot pose -->
  <arg name="x_pos" default="1.0"/>
  <arg name="y_pos" default="-1.0"/>
  <arg name="z_pos" default="0.05"/>
  <arg name="yaw"   default="0.0"/>

  <!-- Optional tools -->
  <arg name="enable_teleop" default="true"/>
  <arg name="enable_visualization" default="true"/>

  <!-- ========================================================== -->
  <!-- Robot Description                                          -->
  <!-- ========================================================== -->

  <param name="robot_description"
         command="$(find xacro)/xacro $(find lmr1_description)/urdf/robot.urdf.xacro"/>

  <!-- ========================================================== -->
  <!-- Gazebo Simulation                                          -->
  <!-- ========================================================== -->

  <include file="$(find gazebo_ros)/launch/empty_world.launch">

    <arg name="world_name"   value="$(arg world_name)"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui"          value="true"/>
    <arg name="debug"        value="false"/>

  </include>

  <!-- ========================================================== -->
  <!-- Actor Dynamic Collision Model Spawn                        -->
  <!-- ========================================================== -->

  <node name="spawn_actor_collision_model"
      pkg="gazebo_ros"
      type="spawn_model"
      output="screen"
      args="-sdf
              -file $(find dynamic_obstacles)/models/actor_collision_model/model.sdf
              -model actor_collision_model
              -x 0.0
              -y 0.0
              -z 0.0"/>

  <!-- ========================================================== -->
  <!-- Robot Spawn                                                -->
  <!-- ========================================================== -->

  <node name="spawn_urdf"
        pkg="gazebo_ros"
        type="spawn_model"
        output="screen"
        args="-urdf
              -model lmr1
              -param robot_description
              -x $(arg x_pos)
              -y $(arg y_pos)
              -z $(arg z_pos)
              -Y $(arg yaw)"/>

  <!-- ========================================================== -->
  <!-- Robot State Publisher                                      -->
  <!-- ========================================================== -->

  <node name="robot_state_publisher"
        pkg="robot_state_publisher"
        type="robot_state_publisher"/>

  <!-- ========================================================== -->
  <!-- Dynamic Obstacle Controller                                -->
  <!-- ========================================================== -->

  <node name="move_cylinder"
        pkg="dynamic_obstacles"
        type="actor_collision_model.py"
        output="screen"/>

  <!-- ========================================================== -->
  <!-- RViz                                                       -->
  <!-- ========================================================== -->

  <group if="$(arg enable_visualization)">

    <node name="rviz"
          pkg="rviz"
          type="rviz"
          output="screen"
          args="-d $(find lmr1_description)/rviz/gazebo_config.rviz"/>

  </group>

  <!-- ========================================================== -->
  <!-- Optional: Keyboard Teleoperation                           -->
  <!-- ========================================================== -->

  <group if="$(arg enable_teleop)">

    <node name="teleop_twist_keyboard"
          pkg="teleop_twist_keyboard"
          type="teleop_twist_keyboard.py"
          output="screen"
          launch-prefix="xterm -fa 'Monospace' -fs 12 -e">

      <remap from="cmd_vel" to="/$(arg namespace)/cmd_vel"/>

    </node>

  </group>

</launch>
